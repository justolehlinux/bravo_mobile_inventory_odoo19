<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="mobile_inventory_page" name="Bravo Mobile Inventory">
        <html lang="ru">
            <head>
                <meta charset="utf-8"/>
                <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover"/>
                <title>Bravo — Инвентаризация</title>
                <link rel="stylesheet" type="text/css" href="/bravo_mobile_inventory/static/src/css/mobile_inventory.css?v=19.0.1.0.3"/>
                <script type="text/javascript" src="/bravo_mobile_inventory/static/src/js/mobile_inventory.js?v=19.0.1.0.3" defer="defer"></script>
            </head>
            <body>
                <main id="bmi-app"
                      t-att-data-can-bind="'1' if can_bind else '0'"
                      t-att-data-can-apply="'1' if can_apply else '0'">
                    <header class="topbar">
                        <h1>Инвентаризация</h1>
                        <p id="session-label" class="muted">Bravo Mobile Inventory · v19.0.1.0.3</p>
                        <p id="js-status" class="ui-status ui-error">Интерфейс JS не запущен. Перезагрузите страницу после обновления модуля.</p>
                    </header>

                    <section id="screen-start" class="screen active">
                        <div class="card">
                            <label class="label" for="location-select">Точная локация склада</label>
                            <select id="location-select" class="input select">
                                <option value="">Выберите локацию</option>
                                <t t-foreach="locations" t-as="loc">
                                    <option t-att-value="loc.id"><t t-esc="loc.complete_name"/></option>
                                </t>
                            </select>
                            <p class="hint">Считается только выбранная локация, без дочерних полок и зон.</p>
                            <button id="start-btn" type="button" class="btn primary wide">Начать подсчёт</button>
                        </div>
                    </section>

                    <section id="screen-count" class="screen">
                        <div class="session-row">
                            <strong id="count-location"></strong>
                            <button id="cancel-btn" type="button" class="btn ghost small">Отменить</button>
                        </div>
                        <div id="toast" class="toast hidden"></div>
                        <div class="card scan-card">
                            <label class="label" for="barcode-input">Скан штрихкода</label>
                            <div class="scan-input-row">
                                <input id="barcode-input" class="input barcode" type="text" inputmode="numeric" autocomplete="off" placeholder="Отсканируйте товар"/>
                                <button id="clear-barcode-btn" class="btn clear" type="button" aria-label="Очистить штрихкод">×</button>
                            </div>
                            <button id="scan-btn" class="btn primary wide scan-action" type="button">Найти товар</button>
                            <p class="hint scan-hint">Сканер ищет автоматически. Кнопка нужна для ручного ввода.</p>
                        </div>

                        <div id="product-panel" class="card hidden">
                            <p id="product-warning" class="notice hidden"></p>
                            <h2 id="product-name"></h2>
                            <p id="product-meta" class="muted"></p>
                            <div class="qty-current">На руках: <strong id="theoretical-qty">0</strong></div>
                            <label class="label" for="counted-input">Посчитано</label>
                            <div class="qty-row">
                                <button id="minus-btn" type="button" class="btn quantity">−</button>
                                <input id="counted-input" class="input counted" type="number" min="0" step="any" placeholder="Enter = оставить как есть"/>
                                <button id="plus-btn" type="button" class="btn quantity">+</button>
                            </div>
                            <div class="buttons">
                                <button id="save-qty-btn" type="button" class="btn primary">Сохранить</button>
                                <button id="skip-btn" type="button" class="btn secondary">Пропустить</button>
                            </div>
                        </div>

                        <div id="unknown-panel" class="card warning hidden">
                            <h2>Штрихкод не найден</h2>
                            <p id="unknown-barcode" class="barcode-value"></p>
                            <div class="buttons">
                                <button id="bind-open-btn" type="button" class="btn primary hidden">Привязать к товару</button>
                                <button id="unknown-skip-btn" type="button" class="btn secondary">Пропустить</button>
                            </div>
                            <p id="bind-permission-hint" class="hint hidden">Привязка доступна менеджеру склада или пользователю с правом Bind Product Barcodes.</p>
                        </div>

                        <div id="bind-panel" class="card hidden">
                            <h2>Привязать штрихкод</h2>
                            <p id="bind-barcode" class="barcode-value"></p>
                            <input id="product-search-input" class="input" type="search" placeholder="Название или код товара"/>
                            <button id="product-search-btn" type="button" class="btn secondary wide">Найти товар</button>
                            <div id="product-results" class="results"></div>
                            <button id="bind-back-btn" type="button" class="btn ghost wide">Назад</button>
                        </div>

                        <div class="card history-card">
                            <h2>Последние сканы</h2>
                            <div id="recent-lines" class="history muted">Пока ничего не сохранено.</div>
                        </div>
                        <button id="finish-btn" type="button" class="btn primary wide finish">Завершить подсчёт</button>
                    </section>

                    <section id="screen-review" class="screen">
                        <div class="card">
                            <h2>Итог подсчёта</h2>
                            <div id="summary-counters" class="counters"></div>
                        </div>
                        <div class="card table-wrap">
                            <table class="summary-table">
                                <thead><tr><th>Товар</th><th>Было</th><th>Счёт</th><th>±</th></tr></thead>
                                <tbody id="summary-lines"></tbody>
                            </table>
                        </div>
                        <div id="bound-summary" class="card hidden"></div>
                        <div class="buttons stacked">
                            <button id="back-count-btn" type="button" class="btn secondary wide">Назад к сканированию</button>
                            <button id="preview-btn" type="button" class="btn primary wide">Проверить применение</button>
                        </div>
                    </section>

                    <section id="screen-preview" class="screen">
                        <div class="card">
                            <h2>Проверка применения</h2>
                            <p id="preview-message" class="notice"></p>
                        </div>
                        <div id="preview-lines"></div>
                        <div class="buttons stacked">
                            <button id="preview-back-btn" type="button" class="btn secondary wide">Назад к итогу</button>
                            <button id="apply-btn" type="button" class="btn danger wide hidden">Применить корректировку</button>
                        </div>
                    </section>
                </main>
            </body>
        </html>
    </template>
</odoo>
