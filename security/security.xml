<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_bravo_inventory" model="ir.module.category">
        <field name="name">Bravo Inventory</field>
        <field name="sequence">35</field>
    </record>

    <record id="privilege_bravo_mobile_inventory" model="res.groups.privilege">
        <field name="name">Mobile Inventory</field>
        <field name="category_id" ref="module_category_bravo_inventory"/>
        <field name="sequence">10</field>
    </record>

    <record id="group_bravo_inventory_barcode_binder" model="res.groups">
        <field name="name">Bind Product Barcodes</field>
        <field name="privilege_id" ref="privilege_bravo_mobile_inventory"/>
        <field name="sequence">10</field>
        <field name="implied_ids" eval="[(4, ref('stock.group_stock_user'))]"/>
    </record>

    <record id="rule_bravo_inventory_session_own" model="ir.rule">
        <field name="name">Mobile inventory: users see their own sessions</field>
        <field name="model_id" ref="model_bravo_inventory_session"/>
        <field name="domain_force">[('user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('stock.group_stock_user'))]"/>
    </record>
    <record id="rule_bravo_inventory_session_manager_all" model="ir.rule">
        <field name="name">Mobile inventory: managers see all sessions</field>
        <field name="model_id" ref="model_bravo_inventory_session"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('stock.group_stock_manager'))]"/>
    </record>
    <record id="rule_bravo_inventory_line_own" model="ir.rule">
        <field name="name">Mobile inventory lines: users see their own session lines</field>
        <field name="model_id" ref="model_bravo_inventory_line"/>
        <field name="domain_force">[('session_id.user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('stock.group_stock_user'))]"/>
    </record>
    <record id="rule_bravo_inventory_line_manager_all" model="ir.rule">
        <field name="name">Mobile inventory lines: managers see all lines</field>
        <field name="model_id" ref="model_bravo_inventory_line"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('stock.group_stock_manager'))]"/>
    </record>
</odoo>
